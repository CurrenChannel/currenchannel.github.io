        <div class="flexbox-y">
            <h1>404 Page not found</h1>
            <p class="center-text shaded">
                Hmm... I cannot find this page dayo... 👉👈 Can we go back?🙏
            </p>
            <a href="/" class="btn btn-primary">Go Back</a>
        </div>
	
		<Image src={ CurrenSad } alt="Curren is Sad" loading="eager" fetchpriority="high" class={"half-body"}/>
	</div>
</MainLayout>
